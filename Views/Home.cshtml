@using Umbraco.Cms.Web.Common.PublishedModels;
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<ContentModels.Home>
@using ContentModels = Umbraco.Cms.Web.Common.PublishedModels;
@{
	Layout = null;
}
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<div class="container mt-5 shadow p-5 bg-light rounded">
    <h1 class="display-1 text-primary">@Model.Value("pageTitel")</h1>
    <div class="lead border-start ps-3 my-4">
        @Model.Value("bodyText") 
    </div>
    <footer class="text-muted small mt-5 border-top pt-3">
        @Model.Value("footerText")
    </footer>
</div>